# Copy this file to .env and fill in all values marked CHANGE_ME.
# Never commit .env — it is gitignored.

# ─── DATABASE ────────────────────────────────────────────────────────────────
# Used by docker-compose and backend
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_PASSWORD=CHANGE_ME

# Direct URL used by backend (and drizzle-kit for migrations)
DATABASE_URL=mysql://cms_user:CHANGE_ME@localhost:3306/cms?timezone=+00:00

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME

# ─── STORAGE (MinIO) ─────────────────────────────────────────────────────────
MINIO_ROOT_USER=cms_admin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BUCKET=plataforma

# ─── EMAIL (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=CHANGE_ME
SMTP_FROM="CMS SPTech <no-reply@example.com>"

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── FRONTEND ────────────────────────────────────────────────────────────────
# Used by Vite (VITE_ prefix exposes to browser bundle)
VITE_API_URL=http://localhost:3001
