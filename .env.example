# ─── FRONTEND ────────────────────────────────────────────────────────────────
# Copy to frontend/.env for local development

# Backend API URL (set after Task 1.1 is complete)
VITE_API_URL=http://localhost:3001

# ─── BACKEND ─────────────────────────────────────────────────────────────────
# Copy relevant vars to backend/.env for local development

# Database
DATABASE_URL=mysql://cms_user:CHANGE_ME@localhost:3306/cms

# JWT — use a long random string (openssl rand -hex 64)
JWT_SECRET=CHANGE_ME

# MySQL — used by docker-compose
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_PASSWORD=CHANGE_ME

# MinIO — used by docker-compose and backend
MINIO_ROOT_USER=cms_admin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BUCKET=plataforma

# Email (SMTP) — for password reset and invites
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=CHANGE_ME
SMTP_FROM="CMS SPTech <no-reply@example.com>"

# App
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000
